local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Rayfield Menu",
   LoadingTitle = "Loading...",
   LoadingSubtitle = "by Rayfield",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = nil,
      FileName = "RayfieldConfig"
   },
   KeySystem = false
})

local Tab = Window:CreateTab("Main Controls", 4483362458) -- Tab icon ID

local Button = Tab:CreateButton({
   Name = "yarak",
   Callback = function()
       local player = game.Players.LocalPlayer
       if player.Character and player.Character:FindFirstChild("Humanoid") then
           -- Set WalkSpeed and JumpPower
           player.Character.Humanoid.WalkSpeed = 100
           player.Character.Humanoid.JumpPower = 100
           
           -- Ensure UseJumpPower is enabled (modern Roblox default)
           player.Character.Humanoid.UseJumpPower = true
           
           Rayfield:Notify({
               Title = "Success",
               Content = "Speed and Jump set to 100",
               Duration = 3,
               Image = 4483362458,
           })
       end
   end,
})
